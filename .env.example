# ──────────────────────────────────────────────────────────
# JBFitness Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# All variables MUST be prefixed with VITE_ to be exposed
# to the browser by Vite.
# ──────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:10000

# Set to "true" to run the app without a real backend (demo data only)
VITE_DEMO_MODE=false

# ── Google Fit Integration (Background Step Tracking) ──────
# Enables the "Connect Google Fit" button on the dashboard.
# Steps are read from Android's hardware pedometer via the
# Google Fitness REST API — this works even when the phone
# screen is off, so the count reflects all-day movement.
#
# How to set this up:
#   1. Go to https://console.cloud.google.com/ and create/select a project.
#   2. Enable "Fitness API" in APIs & Services > Library.
#   3. In APIs & Services > OAuth consent screen, configure your app
#      and add the scope: https://www.googleapis.com/auth/fitness.activity.read
#   4. In APIs & Services > Credentials, create an OAuth 2.0 Client ID
#      of type "Web application".
#   5. Add your production domain AND http://localhost:5173 to
#      "Authorised JavaScript origins".
#   6. Copy the Client ID below.
#
# Leave blank to hide the Google Fit button (app still works without it).
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
