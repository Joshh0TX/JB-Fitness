{
  "name": "jbfitness",
  "version": "1.0.0",
  "description": "JBFitness - Fitness tracking web application",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix jbfitness-backend run dev",
    "dev:all": "concurrently -n frontend,backend -c green,cyan \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && npm --prefix jbfitness-backend install",
    "build": "vite build",
    "build:all": "npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.19.8"
  }
}
