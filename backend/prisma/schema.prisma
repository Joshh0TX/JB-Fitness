generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model meals {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  name       String?   @db.VarChar(100)
  calories   Int?
  protein    Int?
  carbs      Int?
  fats       Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_meals_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model metrics {
  id                 BigInt   @id @default(autoincrement())
  user_id            BigInt
  date               DateTime @db.Date
  calories           Int?     @default(0)
  water_intake       Int?     @default(0)
  workouts_completed Int?     @default(0)
  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_metrics_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model nigerian_foods {
  id           Int      @id @default(autoincrement())
  food_name    String   @db.VarChar(100)
  serving_size String?  @db.VarChar(50)
  calories     Int?
  protein      Decimal? @db.Decimal(5, 2)
  carbs        Decimal? @db.Decimal(5, 2)
  fat          Decimal? @db.Decimal(5, 2)

  @@index([food_name], map: "idx_nigerian_foods_food_name")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model password_reset_tokens {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  token      String    @unique(map: "idx_password_reset_token") @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_password_reset_expires_at")
  @@index([user_id], map: "idx_password_reset_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscriptions {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  plan       String?   @db.VarChar(50)
  status     String?   @db.VarChar(20)
  started_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_subscriptions_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                    BigInt                  @id @default(autoincrement())
  name                  String                  @db.VarChar(100)
  email                 String                  @unique @db.VarChar(100)
  password_hash         String                  @db.VarChar(255)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  meals                 meals[]
  metrics               metrics[]
  password_reset_tokens password_reset_tokens[]
  subscriptions         subscriptions[]
  workouts              workouts[]
  step_logs             step_logs[]
  user_badges           user_badges[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model workouts {
  id              BigInt    @id @default(autoincrement())
  user_id         BigInt
  title           String?   @db.VarChar(100)
  duration        Int?
  calories_burned Int?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_workouts_user_id")
}

model step_logs {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  steps      Int       @default(0)
  date       DateTime  @db.Date
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, date])
  @@index([user_id], map: "idx_step_logs_user_id")
}

model badges {
  id              Int           @id @default(autoincrement())
  name            String        @db.VarChar(100)
  description     String        @db.VarChar(255)
  icon            String        @db.VarChar(10)
  category        String        @db.VarChar(20)
  target_value    Int
  target_unit     String        @db.VarChar(20)
  period          String        @db.VarChar(10)
  user_badges     user_badges[]
}

model user_badges {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  badge_id   Int
  earned_at  DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  badges     badges    @relation(fields: [badge_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, badge_id])
  @@index([user_id], map: "idx_user_badges_user_id")
}